# Copy this to .env and fill in your values
# Never commit .env to git

# Qdrant Cloud (free tier)
QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION=legal_docs

# Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# CORS — your Node.js backend URL
ALLOWED_ORIGINS=["http://localhost:3000","https://your-node-api.railway.app"]

# RAG tuning (optional overrides)
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.6
